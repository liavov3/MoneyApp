# Base URL of the MoneySaver backend (FastAPI, mounted at /api/v1).
# Local dev (simulator on the same machine):
EXPO_PUBLIC_API_URL=http://localhost:8000
# Physical device / Android emulator: use your machine's LAN IP, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8000

# Dev bearer token (auth is config-only for now — no login screen). Set this to
# the backend's DEV_BEARER_TOKEN value. Never commit a real token; .env is
# gitignored. EXPO_PUBLIC_* values are inlined into the JS bundle at build time.
EXPO_PUBLIC_API_TOKEN=your-dev-bearer-token
