# Base URL of the MoneySaver backend (FastAPI, mounted at /api/v1).
# Local dev (simulator on the same machine):
EXPO_PUBLIC_API_URL=http://localhost:8000
# Physical device / Android emulator: use your machine's LAN IP, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8000
#
# The dev bearer token is NOT stored here — paste it once in the app's token
# gate screen (kept in the device SecureStore). Never commit a real token.
