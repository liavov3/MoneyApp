# Money App backend — environment configuration template.
# Copy to `.env` and adjust. NEVER commit a real .env (see .gitignore).
# NEVER put production secrets, tokens, or PII in this file.

# --- Database (PostgreSQL) ---
# DEFAULT PATH: Neon (or any managed Postgres). Paste the connection string
# from the Neon dashboard. A bare libpq URL works — the app normalizes it for
# the asyncpg driver (forces +asyncpg, translates `sslmode`, drops the
# unsupported `channel_binding`, defaults `ssl=require` for remote hosts), so
# any of these forms are accepted:
#   postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#   postgresql+asyncpg://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require
# Use a NON-production Neon database/branch for development and tests.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# OPTIONAL — dedicated test database. Recommended: a separate Neon BRANCH so the
# test suite's writes never touch your development data. If unset, tests fall
# back to DATABASE_URL (safe: tests use random UUIDs and never drop data, but a
# branch keeps the dev DB clean).
# TEST_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@EP-yyyy-test.REGION.aws.neon.tech/neondb?sslmode=require

# OPTIONAL PATH: local Docker Postgres (with pgvector). Docker is NOT required;
# it is just one way to provide a DATABASE_URL. To use it, run
# `docker compose up -d` and set:
#   DATABASE_URL=postgresql+asyncpg://money:money@localhost:5432/money_app

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Auth (v0.0.1 single-user, server-resolved) ---
# Static dev bearer token. The client sends `Authorization: Bearer <token>`;
# the server resolves it to the single dev principal (API_CONTRACT §3). Held in
# config / secrets manager only — NEVER commit a real value (this file ships a
# FAKE placeholder only). Generate a local random value for your real .env, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# When unset, every authenticated request returns 401.
DEV_BEARER_TOKEN=replace-with-a-local-only-random-token
