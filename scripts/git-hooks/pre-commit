#!/bin/sh
# MoneySaver pre-commit guard — secret safety + test reminder. Non-destructive:
# it only REJECTS a commit (with a message) when a secret is staged; it never
# deletes or rewrites anything, and never prints the secret value.
#
# Install (from repo root):  cp scripts/git-hooks/pre-commit .git/hooks/pre-commit
# Bypass in an emergency:     git commit --no-verify   (avoid — fix the leak)

# 1) Never commit a real .env (only .env.example is allowed).
if git diff --cached --name-only | grep -E '(^|/)\.env($|\.)' | grep -qv '\.env\.example$'; then
  echo "pre-commit: refusing to commit a .env file (secrets). Unstage it." >&2
  exit 1
fi

# 2) Block real secrets in staged content: Neon DSN, npg_ password, live token.
#    Placeholder lines (.env.example / README) are allow-listed.
if git diff --cached -U0 \
   | grep -nE 'npg_[A-Za-z0-9]+|postgresql(\+asyncpg)?://[^[:space:]]*neon\.tech|DEV_BEARER_TOKEN=[A-Za-z0-9._-]{12,}' \
   | grep -qvE 'USER:PASSWORD|EP-xxxx|replace-with'; then
  echo "pre-commit: a real secret (Neon URL / npg_ password / token) appears staged. Remove it." >&2
  exit 1
fi

# 3) Non-blocking reminder (never logs secrets).
echo "pre-commit: secret checks passed. Reminder: run 'cd backend && python -m pytest' before pushing." >&2
exit 0
